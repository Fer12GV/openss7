# OpenSS7 Deploy System — Variables de entorno
# Copiar este archivo como .env y completar los valores reales.
# NUNCA commitear .env al repositorio (ya está en .gitignore).

# ============================================================
# BUILD — Variables para compilacion en Docker
# ============================================================

# Version del kernel del host (se puede dejar vacio para auto-detectar en deploy.py)
KERNEL_VERSION=

# Numero de jobs paralelos para make (dejar vacio = auto = nproc)
BUILD_JOBS=

# ============================================================
# VPS — Credenciales del servidor de produccion (HostGator)
# ============================================================

# IP del servidor VPS
VPS_HOST=129.121.60.55

# Puerto SSH (VPS HostGator usa 22022)
VPS_PORT=22022

# Usuario SSH
VPS_USER=root

# Contraseña SSH del root
# IMPORTANTE: completar antes de ejecutar deploy.py deploy-vps
VPS_PASSWORD=
